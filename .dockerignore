# ========================================
# .dockerignore - Backend Node.js CENTER
# ========================================
# EXCLUSION: Fichiers lourds et inutiles pour le déploiement
#
# Note: Dockerfile.chat et la moderation_api/ ont leurs propres contextes.
# Ce fichier gouverne le build context du Dockerfile Node.js principal
# ET de Dockerfile.chat (même répertoire racine).
#
# Les exceptions !chat_agent_api.py etc. permettent à Dockerfile.chat
# d'accéder aux fichiers Python sans affecter l'image Node.js
# (le Dockerfile Node.js ne COPY pas ces fichiers).

# ========================================
# PYTHON - TOUT EXCLURE sauf les fichiers nécessaires à Dockerfile.chat
# ========================================
*.py
*.pyc
*.pyo
*.pyd
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
requirements*.txt
venv/
env/
ENV/
.venv
pip-log.txt
.pytest_cache/

# ── Exceptions pour Dockerfile.chat ──────────────────────────────────────
!chat_agent_api.py
!requirements-chat.txt
!models/*.py
!models/unified_agent.py

# ── Exceptions pour Dockerfile.recommend ─────────────────────────────────
!food_recommend_api.py
!requirements-recommend.txt

# ── Exceptions pour Dockerfile.vlm ───────────────────────────────────────
!vlm_api.py
!requirements-vlm.txt

# ========================================
# DOSSIERS LOURDS - IA/ML (EXCLURE)
# ========================================
smolvlm_cache/
mistral_models/
stable_diffusion/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.h5
*.pkl
*.model

# ========================================
# STOCKAGE LOCAL (Cloudinary utilisé)
# ========================================
storage/
uploads/
temp/
*.tmp
*.temp

# ========================================
# NODE.JS
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ========================================
# FICHIERS DE TEST
# ========================================
test/
tests/
test-*.js
test-*.ps1
test-*.sh
check-user.js
update-password.js
*.test.js
*.test.py
*.spec.js

# ========================================
# DOCUMENTATION
# ========================================
README.md
DEPLOY_GUIDE.md
RECAP.md
*.md
docs/

# ========================================
# DOCKER
# ========================================
docker-compose*.yml
Dockerfile
.dockerignore*

# ========================================
# GIT
# ========================================
.git/
.gitignore
.gitattributes

# ========================================
# ENVIRONNEMENT LOCAL
# ========================================
.env
.env.local
.env.*.local

# ========================================
# IDE ET SYSTÈME
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ========================================
# LOGS ET CACHE
# ========================================
.cache/
*.log
logs/
